{
  "name": "zernio-dg-carousels",
  "version": "1.0.0",
  "description": "Interactive carousel components for modern web development",
  "main": "index.html",
  "scripts": {
    "dev": "npx live-server --port=3000 --open=/index.html",
    "dev:enhanced": "npx live-server --port=3000 --open=/enhanced.html",
    "dev:demo": "npx live-server --port=3000 --open=/demo.html",
    "dev:test": "npx live-server --port=3000 --open=/test.html",
    "dev:robust": "npx live-server --port=3000 --open=/robust.html",
    "start": "npm run dev",
    "start:enhanced": "npm run dev:enhanced",
    "start:demo": "npm run dev:demo",
    "start:robust": "npm run dev:robust",
    "test": "npx live-server --port=3000 --open=/test.html?autorun=true",
    "test:manual": "npm run dev:test",
    "build": "mkdir -p dist && cp -r css js src test *.html package.json dist/",
    "build:prod": "npm run build && echo \"Production build complete in dist/\"",
    "serve:prod": "npx live-server dist --port=3001",
    "verify": "npm test && echo \"All tests passed - ready for production\"",
    "lint": "echo \"Linting files...\"",
    "format": "echo \"Formatting code...\"",
    "audit": "npm test"
  },
  "keywords": ["carousel", "slideshow", "web-components", "javascript"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "live-server": "^1.2.2"
  }
}
